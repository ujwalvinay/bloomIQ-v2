MONGODB_URI=
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
NODE_ENV=development

# Password reset links (frontend origin, e.g. Next app on port 3001)
APP_ORIGIN=
# Optional: Resend (https://resend.com) — required in production for reset emails
RESEND_API_KEY=
MAIL_FROM=

# Optional: Google AI / Gemini — enriches new plants (light level + care guide)
# Create at https://aistudio.google.com/apikey (keys may look like AIza… or AQ.…).
# Prefer GEMINI_API_KEY=... with no spaces around "=". GOOGLE_API_KEY is also read as fallback.
GEMINI_API_KEY=
# GOOGLE_API_KEY=
# Optional override (default: gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash
