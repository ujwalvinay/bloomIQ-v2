# Copy to .env and fill in values. Required fields are validated when the API loads env.

# Do not set NODE_ENV=development in Render/host env: Next needs production during `npm run build`
# (otherwise prerender fails with "<Html> should not be imported outside of pages/_document").
# Locally, omit NODE_ENV or use development; the build script forces production for `next build`.

# --- Required ---
MONGODB_URI=
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# --- Optional: Google AI / Gemini ---
# Used for: new plant profile (light + care guide), plant care chat, insights AI brief.
# Create a key at https://aistudio.google.com/apikey (may look like AIza… or AQ.…).
# Prefer GEMINI_API_KEY with no spaces around "=". GOOGLE_API_KEY is also read as fallback.
GEMINI_API_KEY=
# GOOGLE_API_KEY=

# Optional model id (defaults try several flash models in code).
# GEMINI_MODEL=gemini-2.0-flash

# --- Optional: legacy email password reset ---
# Base URL of the frontend (e.g. http://localhost:3001) for links built in forgot-password.
APP_ORIGIN=

# Resend (https://resend.com) — only if you call POST /api/auth/forgot-password for email flows.
RESEND_API_KEY=
MAIL_FROM=
