# Copy to .env.local (or .env) for local overrides. Next.js loads .env.local automatically.

# Backend origin used by next.config.mjs rewrites: browser /api/* → this host.
# Default in next.config.mjs is http://localhost:3000 if unset.
API_PROXY_TARGET=http://localhost:3000

# Public origin for <img src> and absolute URLs to binary API routes (avatars, plant photos).
# In development, if unset, code falls back to http://localhost:3000 (see src/lib/backend-origin.ts).
# Set this when the API runs on a different host/port than the default.
# NEXT_PUBLIC_API_PROXY_TARGET=http://localhost:3000
